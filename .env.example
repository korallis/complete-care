# =============================================================================
# Complete Care — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# -----------------------------------------------------------------------------
# Database (Vercel Postgres / Neon)
# -----------------------------------------------------------------------------
# Get from: Vercel dashboard → Storage → Create Postgres database
DATABASE_URL=

# -----------------------------------------------------------------------------
# Authentication (Auth.js v5)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL for Auth.js callbacks
AUTH_URL=http://localhost:3200

# Google OAuth Provider
# Get from: Google Cloud Console → APIs & Services → Credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# Stripe (Payments)
# -----------------------------------------------------------------------------
# Get from: Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Get from: stripe listen --forward-to localhost:3200/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe Price IDs (from Stripe dashboard → Products)
STRIPE_PRO_PRICE_ID=price_
STRIPE_ENTERPRISE_PRICE_ID=price_

# -----------------------------------------------------------------------------
# AWS Bedrock (AI)
# -----------------------------------------------------------------------------
# Get from: AWS IAM → Create user with Bedrock access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------
# Get from: Google Cloud Console → APIs & Services → Credentials
# Restrict key to: Maps JavaScript API, Geocoding API, Directions API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Public URL of the application (used for redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3200
